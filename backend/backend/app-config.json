{
  "stack": "python-3.13",
  "startup_command": "python3 -m uvicorn app.app:app --host 0.0.0.0 --port $X_ZOHO_CATALYST_LISTEN_PORT",
  "env_variables": {
    "DB_TYPE": "mysql",
    "DB_HOST": "${CATALYST_DATASTORE_HOST}",
    "DB_PORT": "3306",
    "DB_USER": "${CATALYST_DATASTORE_USER}",
    "DB_PASSWORD": "${CATALYST_DATASTORE_PASSWORD}",
    "DB_NAME": "KarnatakaPoliceFIRDB",
    "QUICKML_ENDPOINT_URL": "${QUICKML_ENDPOINT_URL}",
    "QUICKML_ACCESS_TOKEN": "${QUICKML_ACCESS_TOKEN}",
    "USE_MOCK_LLM": "false"
  }
}
